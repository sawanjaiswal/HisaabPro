      {/* Stats row skeleton */}
      <div className="grid grid-cols-2 gap-3 mb-5">
        {[0, 1].map(i => (
          <div key={`skeleton-${i}`} className="rounded-xl p-4 animate-pulse" style={{ backgroundColor: 'var(--card-bg)', border: '1px solid var(--card-border)' }}>
