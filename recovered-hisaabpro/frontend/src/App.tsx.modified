              <ProtectedRoute>
                <RouteErrorBoundary routeName="team">
                  <Layout>
                    <Team />
                  </Layout>
                </RouteErrorBoundary>
              </ProtectedRoute>
            }
          />
          <Route
            path={ROUTES.team.new}
            element={
              <ProtectedRoute>
                <RouteErrorBoundary routeName="add-team-member">
                  <Layout>
                    <AddTeamMember />
                  </Layout>
                </RouteErrorBoundary>
              </ProtectedRoute>
            }
          />
          <Route
