        <div className="w-7 h-7 rounded-lg animate-pulse" style={{ backgroundColor: 'var(--skeleton-base)' }} />
        <div className="h-4 w-24 rounded animate-pulse" style={{ backgroundColor: 'var(--skeleton-base)' }} />
