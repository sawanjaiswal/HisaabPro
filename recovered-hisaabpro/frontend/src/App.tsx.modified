            }
          />
          <Route
            path={ROUTES.analytics}
            element={
              <ProtectedRoute>
                <RouteErrorBoundary routeName="reports">
                  <FeatureRoute feature={{ featureKey: 'analytics', featureName: 'Analytics', requiredPlan: 'Pro' }}>
                    <Layout>
