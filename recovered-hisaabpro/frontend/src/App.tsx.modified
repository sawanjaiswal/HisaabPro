function ProtectedRoute({ children }: { children: ReactNode }) {
  const { isAuthenticated, isLoading } = useAuth();

  if (isLoading) {
    return <div className="flex items-center justify-center min-h-screen">Loading...</div>;
  }

  return isAuthenticated ? <>{children}</> : <Navigate to={ROUTES.login} />;
}

/** Route-level feature gate — shows FeatureGateDrawer and redirects back if feature not in plan */
function FeatureRoute({ feature, children }: { feature: FeatureGateConfig; children: ReactNode }) {
  const { features, isLoading } = useSubscription();
  const { showFeatureGate } = useFeatureGate();
  const navigate = useNavigate();
  const gateShownRef = useRef(false);

  useEffect(() => {
    if (isLoading || gateShownRef.current) return;
    const key = feature.featureKey as keyof typeof features;
    if (!features[key]) {
      gateShownRef.current = true;
      showFeatureGate(feature);
      navigate(-1);
    }
  }, [isLoading, features, feature, showFeatureGate, navigate]);

  if (isLoading) return <div className="flex items-center justify-center min-h-screen">Loading...</div>;
  const key = feature.featureKey as keyof typeof features;
  if (!features[key]) return null;
  return <>{children}</>;
}

/** Global FeatureGate drawer — reads from Zustand store, renders from any component via useFeatureGate() */
function FeatureGateGlobal() {
  const { open, config, hideFeatureGate } = useFeatureGate();
  return <FeatureGateDrawer open={open} config={config} onClose={hideFeatureGate} />;
}

/** Redirect old /ledger URLs to new /statement URLs */
function LedgerRedirect({ to }: { to: 'customers' | 'suppliers' }) {
  const { id } = useParams<{ id: string }>();
  return <Navigate to={`/${to}/${id}/statement`} replace />;
}

/** Self-contained banner: reads useBilling internally so Layout doesn't need to depend on it */
function OverflowBannerGlobal() {
  const { limits } = useBilling();
  const navigate = useNavigate();
  if (!limits?.isInOverflow && !limits?.isEnforced) return null;
  return (
    <OverflowBanner
      isEnforced={limits?.isEnforced ?? false}
      graceDaysRemaining={limits?.graceDaysRemaining ?? null}
      onUpgrade={() => navigate(ROUTES.subscription.plans)}
    />
  );
}

function Layout({ children }: { children: ReactNode }) {
  const { logout, user } = useAuth();
  const toast = useToast();
  const { t } = useLanguage();
  const navigate = useNavigate();
  const [sidebarOpen, setSidebarOpen] = useState(true);
  const [mobileMenuOpen, setMobileMenuOpen] = useState(false);
  const [hideBottomNav, setHideBottomNav] = useState(false);
  const [quickActionsOpen, setQuickActionsOpen] = useState(false);
  const { canInstall, promptInstall, dismissInstall } = usePWAInstall();
  const { tier, tierName, isFree, planChange, dismissPlanChange } = useSubscription();
  const location = window.location.pathname;

  // Swipe-back gesture (iPhone-style)
  const { isActive: swipeActive, progress: swipeProgress } = useSwipeBack({
    enabled: true,
    edgeWidth: 50,
    threshold: 100,
  });

  // Online/offline status with toast notifications
  const { isOnline } = useOnlineStatusWithCallbacks({
    onOnline: () => {
      toast.success(t.backOnline);
    },
    onOffline: () => {
      toast.warning(t.youAreOffline);
    },
  });

  // Offline-first: hydrate IndexedDB with server data on auth + reconnect
  useDataHydration(!!user);

  // Customer overflow reminder toast (fires once on load if in grace window)
  useOverflowReminder();

  // Sync deadline enforcement
  const { syncExpired, isFirstTimeUser } = useSyncDeadline();
  const [lockoutDismissed, setLockoutDismissed] = useState(false);

  // Reset dismissal when sync status changes
  useEffect(() => {
    if (!syncExpired) setLockoutDismissed(false);
  }, [syncExpired]);

  // Watch for data-hide-bottom-nav attribute changes
  useEffect(() => {
    const checkBottomNav = () => {
      // Check for modals/drawers or data-modal-open on body
      const shouldHide =
        document.querySelector('[data-hide-bottom-nav="true"]') !== null ||
        document.body.hasAttribute('data-modal-open');
      setHideBottomNav(shouldHide);
    };

    // Check immediately
    checkBottomNav();

    const observer = new MutationObserver(checkBottomNav);

    // Observe document.body to catch all modals/drawers
    // childList:true catches node removals (when modals unmount via return null)
    // attributes:true catches attribute changes (data-modal-open on body)
    observer.observe(document.body, {
      childList: true,
      attributes: true,
      subtree: true,
      attributeFilter: ['data-hide-bottom-nav', 'data-modal-open'],
    });

    return () => observer.disconnect();
  }, [location]);

  const isActive = (path: string) => location === path;

  // Navigation sections - Grouped by purpose
  const navSections = [
    {
      label: t.daily,
      items: [
        { path: ROUTES.dashboard, label: t.dashboard, icon: LayoutDashboard },
        { path: ROUTES.dailyEntry, label: t.dailyEntry, icon: FileText },
        { path: ROUTES.customers.list, label: t.customers, icon: Users },
        { path: ROUTES.suppliers.list, label: t.suppliers, icon: Factory },
        { path: ROUTES.payments.list, label: t.paymentsList, icon: Wallet },
        { path: ROUTES.deliveryMode, label: t.deliveryMode, icon: Truck },
      ],
    },
    {
      label: t.business,
      items: [
        { path: ROUTES.products, label: t.products, icon: Package },
        { path: ROUTES.orders, label: t.ordersPageTitle || 'Orders', icon: ClipboardList },
        { path: ROUTES.team.list, label: t.teamMembers || 'Team', icon: UsersRound },
        { path: '/backup', label: t.backup, icon: Database },
      ],
    },
    {
      label: t.more,
      items: [
        { path: '/referral-earn', label: t.referAndEarn, icon: Gift },
        { path: ROUTES.pricing, label: t.upgrade, icon: CreditCard, planTier: isFree ? undefined : tier, planTierName: isFree ? undefined : tierName },
        { path: ROUTES.feedback, label: t.feedback, icon: MessageSquare },
        { path: ROUTES.faq, label: t.faq, icon: HelpCircle },
        { path: ROUTES.settings, label: t.settings, icon: Settings },
      ],
    },
    {
      label: t.comingSoon,
      items: [
        { path: '#coins', label: t.doodhCoins || 'Doodh Coins', icon: Coins, comingSoon: true },
        { path: '#pos', label: t.pos, icon: ShoppingCart, comingSoon: true },
        { path: '#reports', label: t.reports, icon: BarChart3, comingSoon: true },
        { path: '#analytics', label: t.analytics, icon: TrendingUp, comingSoon: true },
        { path: '#quality-reports', label: t.qualityAnalytics || 'Quality Analytics', icon: Activity, comingSoon: true },
        { path: '#track-routes', label: t.trackRoutes || 'Track Routes', icon: Navigation, comingSoon: true },
      ],
    },
  ];

  // Flat list for desktop sidebar and animation index
  const navItems = navSections.flatMap(s => s.items);

  return (
    <div
      className="min-h-screen flex transition-colors duration-200"
      style={{
        backgroundColor: 'var(--bg-secondary)',
        paddingBottom: 'var(--page-bottom)',
      }}
    >
      {/* Sync deadline lockout overlay */}
      {(syncExpired || isFirstTimeUser) && !lockoutDismissed && (
        <SyncRequiredLockout
          isFirstTimeUser={isFirstTimeUser}
          onDismiss={() => setLockoutDismissed(true)}
        />
      )}

      {/* Swipe Back Indicator */}
      <SwipeBackIndicator progress={swipeProgress} isActive={swipeActive} />

      {/* Mobile Header - All Screen Sizes - Height: 56px (14 * 4px) */}
      <AppHeader
        userName={user?.name}
        userInitial={user?.name?.charAt(0).toUpperCase()}
        onMenuClick={() => setMobileMenuOpen(!mobileMenuOpen)}
      />

      {/* Mobile Sidebar Menu */}
      <MobileMenu
        isOpen={mobileMenuOpen}
        onClose={() => setMobileMenuOpen(false)}
        user={user}
        navSections={navSections}
        navItemsCount={navItems.length}
        isActive={isActive}
        onLogout={logout}
        logoutLabel={t.logout}
      />

      {/* Sidebar - Hidden (Using Mobile Header Instead) */}
      <DesktopSidebar
        sidebarOpen={sidebarOpen}
        onToggle={setSidebarOpen}
        isOnline={isOnline}
        navItems={navItems}
        isActive={isActive}
        user={user}
        onLogout={logout}
        logoutLabel={t.logout}
        profileLabel={t.profile}
        offlineLabel="You are offline"
      />

      {/* Main Content */}
      <main
        className={`flex-1 transition-all duration-300 max-w-full overflow-x-clip ${
          sidebarOpen ? 'lg:ml-64' : 'lg:ml-20'
        }`}
        style={{
          paddingTop: 'var(--page-top)',
        }}
      >
        <HydrationGate />
        <OfflineDataBanner />
        <DriveWarningBanner />
        <PriceAnnouncementBanner />
        <OverflowBannerGlobal />
        <div key={location} className="page-transition">
          {children}
        </div>
      </main>

      {/* WhatsApp Contact Button */}
      <WhatsAppContact />

      {/* FAB removed */}

      {/* PWA Install Banner */}
      {canInstall && !hideBottomNav && (
        <div
          className="fixed left-0 right-0 z-40 px-4 py-2 flex items-center gap-3 lg:hidden"
          style={{
            bottom: '72px',
            backgroundColor: 'var(--brand-primary, #1e3a5f)',
            color: 'var(--text-inverse)',
          }}
        >
          <div className="flex-1 min-w-0">
            <p className="text-sm font-medium truncate">{t.installApp || 'Install DudhHisaab App'}</p>
            <p className="text-xs opacity-75 truncate">{t.installAppDesc || 'Quick access from home screen'}</p>
          </div>
          <button
            onClick={promptInstall}
            className="px-3 py-1.5 text-xs font-semibold rounded-lg shrink-0"
            style={{ backgroundColor: 'var(--bg-primary)', color: 'var(--brand-primary, #1e3a5f)' }}
          >
            {t.install || 'Install'}
          </button>
          <button
            onClick={dismissInstall}
            className="text-lg leading-none shrink-0"
            style={{ color: 'var(--text-inverse)', opacity: 0.6 }}
            aria-label="Dismiss"
          >
            &times;
          </button>
        </div>
      )}

      {/* Bottom Navigation - All Screen Sizes */}
      <BottomNav
        currentPath={location}
        hidden={hideBottomNav}
      />

      {/* Quick Actions Drawer */}
      <ResponsiveModal
        open={quickActionsOpen}
        onOpenChange={setQuickActionsOpen}
        title={t.quickActions}
      >
        <div className="space-y-2">
          {/* Start Smart Delivery */}
          <button
            onClick={() => {
              navigate(ROUTES.deliveryMode);
              setQuickActionsOpen(false);
            }}
            className="w-full flex items-center gap-4 p-4 rounded-xl transition-colors active:scale-[0.98]"
            style={{ backgroundColor: 'var(--bg-secondary)' }}
          >
            <div className="w-11 h-11 rounded-full flex items-center justify-center flex-shrink-0" style={{ backgroundColor: 'var(--brand-primary)', color: 'var(--text-inverse)' }}>
              <Truck className="w-5 h-5" strokeWidth={2} />
            </div>
            <div className="flex-1 text-left">
              <p className="text-sm font-semibold" style={{ color: 'var(--text-primary)' }}>{t.startDeliveryMode}</p>
              <p className="text-xs mt-0.5" style={{ color: 'var(--text-tertiary)' }}>{t.beginDailyEntries}</p>
            </div>
          </button>

          {/* Add Payment */}
          <button
            onClick={() => {
              navigate(ROUTES.payments.new);
              setQuickActionsOpen(false);
            }}
            className="w-full flex items-center gap-4 p-4 rounded-xl transition-colors active:scale-[0.98]"
            style={{ backgroundColor: 'var(--bg-secondary)' }}
          >
            <div className="w-11 h-11 rounded-full flex items-center justify-center flex-shrink-0" style={{ backgroundColor: 'var(--brand-primary)', color: 'var(--text-inverse)' }}>
              <Wallet className="w-5 h-5" strokeWidth={2} />
            </div>
            <div className="flex-1 text-left">
              <p className="text-sm font-semibold" style={{ color: 'var(--text-primary)' }}>{t.addPayment}</p>
              <p className="text-xs mt-0.5" style={{ color: 'var(--text-tertiary)' }}>{t.recordPayment}</p>
            </div>
          </button>

          {/* Add Customer */}
          <button
            onClick={() => {
              navigate(ROUTES.customers.new);
              setQuickActionsOpen(false);
            }}
            className="w-full flex items-center gap-4 p-4 rounded-xl transition-colors active:scale-[0.98]"
            style={{ backgroundColor: 'var(--bg-secondary)' }}
          >
            <div className="w-11 h-11 rounded-full flex items-center justify-center flex-shrink-0" style={{ backgroundColor: 'var(--brand-primary)', color: 'var(--text-inverse)' }}>
              <Users className="w-5 h-5" strokeWidth={2} />
            </div>
            <div className="flex-1 text-left">
              <p className="text-sm font-semibold" style={{ color: 'var(--text-primary)' }}>{t.addCustomer}</p>
              <p className="text-xs mt-0.5" style={{ color: 'var(--text-tertiary)' }}>{t.customerDesc}</p>
            </div>
          </button>

          {/* Add Supplier */}
          <button
            onClick={() => {
              navigate(ROUTES.suppliers.new);
              setQuickActionsOpen(false);
            }}
            className="w-full flex items-center gap-4 p-4 rounded-xl transition-colors active:scale-[0.98]"
            style={{ backgroundColor: 'var(--bg-secondary)' }}
          >
            <div className="w-11 h-11 rounded-full flex items-center justify-center flex-shrink-0" style={{ backgroundColor: 'var(--brand-primary)', color: 'var(--text-inverse)' }}>
              <Factory className="w-5 h-5" strokeWidth={2} />
            </div>
            <div className="flex-1 text-left">
              <p className="text-sm font-semibold" style={{ color: 'var(--text-primary)' }}>{t.addSupplier}</p>
              <p className="text-xs mt-0.5" style={{ color: 'var(--text-tertiary)' }}>{t.addSupplierDesc}</p>
            </div>
          </button>
        </div>
      </ResponsiveModal>

      {/* Plan Change Drawer — upgrade celebration or expiry notice */}
      <PlanChangeDrawer planChange={planChange} onDismiss={dismissPlanChange} />
    </div>
  );
}

function App() {
  // Initialize theme on app load - MUST be at root level
  useTheme();

  // Initialize interaction discovery coachmarks
  useEffect(() => {
    useDiscoveryStore.getState().initialize();
  }, []);

  // Initialize font size on app load
  useEffect(() => {
    const savedFontSize = storage.getFontSize();
    if (savedFontSize && savedFontSize !== 'normal') {
      document.documentElement.setAttribute('data-font-size', savedFontSize);
    }
  }, []);

  // Prevent flash of unstyled content by adding preload class
  useEffect(() => {
    document.body.classList.add('preload');
    setTimeout(() => {
      document.body.classList.remove('preload');
    }, TIMINGS.focusDelay);
  }, []);

  return (
    <ErrorBoundary>
      <QueryClientProvider client={queryClient}>
        <BrowserRouter>
          <LanguageProvider>
            <ScrollToTop />
            <NewToastContainer />
            <AppBlockerDrawer />
            <AuthProvider>
              <InactivityWarningModal />
              <FeatureGateGlobal />
              <RegistrationProvider>
              <Suspense fallback={<PageLoader />}>
              <Routes>
          {/* ── Auth routes ── */}
          <Route path={ROUTES.onboarding} element={<RouteErrorBoundary routeName="auth"><Onboarding /></RouteErrorBoundary>} />
          <Route path={ROUTES.login} element={<RouteErrorBoundary routeName="auth"><Login /></RouteErrorBoundary>} />
          <Route path={ROUTES.forgotPassword} element={<RouteErrorBoundary routeName="auth"><ForgotPassword /></RouteErrorBoundary>} />
          <Route path={ROUTES.register} element={<RouteErrorBoundary routeName="auth"><Register /></RouteErrorBoundary>} />
          <Route path={ROUTES.registerNoWhatsApp} element={<RouteErrorBoundary routeName="auth"><RegisterNoWhatsApp /></RouteErrorBoundary>} />
          <Route path={ROUTES.verifyOtp} element={<RouteErrorBoundary routeName="auth"><VerifyOTP /></RouteErrorBoundary>} />
          <Route path={ROUTES.setPassword} element={<RouteErrorBoundary routeName="auth"><SetPassword /></RouteErrorBoundary>} />
          <Route path="/capacitor-test" element={<CapacitorTest />} />

          {/* ── Public legal routes (no auth required) ── */}
          <Route path={ROUTES.privacyPolicy} element={<RouteErrorBoundary routeName="legal"><PrivacyPolicy /></RouteErrorBoundary>} />

          {/* ── Public portal (customer/supplier self-serve — no auth) ── */}
          <Route path="/s/:token" element={<RouteErrorBoundary routeName="portal"><Portal /></RouteErrorBoundary>} />

          {/* ── Public statement view (WhatsApp shared link — no auth) ── */}
          <Route path="/stmt/:token" element={<RouteErrorBoundary routeName="statement"><StatementView /></RouteErrorBoundary>} />

          {/* ── Team worker auth (public — no login required) ── */}
          <Route path="/worker-login" element={<RouteErrorBoundary routeName="worker-auth"><WorkerLogin /></RouteErrorBoundary>} />
          <Route path="/team-invite/:token" element={<RouteErrorBoundary routeName="team-invite"><TeamInvite /></RouteErrorBoundary>} />

          {/* ── Team feature marketing page (public) ── */}
          <Route path={ROUTES.teamFeature} element={<RouteErrorBoundary routeName="team-feature"><TeamFeaturePage /></RouteErrorBoundary>} />

          {/* ── Delivery routes ── */}
          <Route
            path={ROUTES.deliveryMode}
            element={
              <ProtectedRoute>
                <RouteErrorBoundary routeName="delivery">
                  <FeatureRoute feature={{ featureKey: 'deliveryTracking', featureName: 'Smart Delivery', requiredPlan: 'Pro' }}>
                    <DeliveryMode />
                  </FeatureRoute>
                </RouteErrorBoundary>
              </ProtectedRoute>
            }
          />
          <Route
            path={ROUTES.deliveryRoutePreview}
            element={
              <ProtectedRoute>
                <RouteErrorBoundary routeName="delivery">
                  <FeatureRoute feature={{ featureKey: 'deliveryTracking', featureName: 'Smart Delivery', requiredPlan: 'Pro' }}>
                    <DeliveryRoutePreview />
                  </FeatureRoute>
                </RouteErrorBoundary>
              </ProtectedRoute>
            }
          />
          <Route
            path={ROUTES.deliveryActive}
