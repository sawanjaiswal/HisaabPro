generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// === Foundation models — expanded per feature via /f ===

model User {
  id            String   @id @default(cuid())
  phone         String   @unique
  name          String?
  email         String?
  passwordHash  String?
  pinHash       String?
  biometricEnabled Boolean @default(false)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  businessUsers  BusinessUser[]
  refreshTokens  RefreshToken[]
  stockMovements StockMovement[]

  @@index([phone])
}

model Business {
  id            String   @id @default(cuid())
  name          String
  phone         String?
  email         String?
  address       String?
  city          String?
  state         String?
  pincode       String?
  logoUrl       String?
  businessType  String   @default("general")
  currencyCode  String   @default("INR")
  financialYearStart Int @default(4) // April
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  businessUsers    BusinessUser[]
  parties          Party[]
  partyGroups      PartyGroup[]
  customFields     CustomFieldDefinition[]
  categories       Category[]
  units            Unit[]
  products         Product[]
  unitConversions  UnitConversion[]
  stockMovements   StockMovement[]
  inventorySetting InventorySetting?

  @@index([name])
}

model BusinessUser {
  id         String   @id @default(cuid())
  userId     String
  businessId String
  role       String   @default("owner")
  isActive   Boolean  @default(true)
  joinedAt   DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  business Business @relation(fields: [businessId], references: [id], onDelete: Restrict)

  @@unique([userId, businessId])
  @@index([businessId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  deviceInfo String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model OtpCode {
  id        String   @id @default(cuid())
  phone     String
  code      String
  attempts  Int      @default(0)
  verified  Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([phone, verified])
  @@index([expiresAt])
}

model IdempotencyLog {
  id        String   @id @default(cuid())
  key       String   @unique
  userId    String
  response  Json
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

model Feedback {
  id         String   @id @default(cuid())
  userId     String?
  type       String   // bug, feature, general
  message    String
  rating     Int?
  screenshot String?  // base64 or URL
  metadata   Json?    // device info, page, etc.
  status     String   @default("open") // open, reviewed, resolved
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([status])
}

// === Party Management ===

model Party {
  id                String   @id @default(cuid())
  businessId        String
  name              String
  phone             String?
  email             String?
  companyName       String?
  type              String   @default("CUSTOMER") // CUSTOMER, SUPPLIER, BOTH
  groupId           String?
  tags              String[] @default([])
  gstin             String?
  pan               String?
  creditLimit       Int      @default(0) // in paise, 0 = no limit
  creditLimitMode   String   @default("WARN") // WARN, BLOCK
  outstandingBalance Int     @default(0) // in paise, positive = receivable, negative = payable
  totalBusiness     Int      @default(0) // in paise, lifetime total
  lastTransactionAt DateTime?
  notes             String?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  business       Business           @relation(fields: [businessId], references: [id], onDelete: Restrict)
  group          PartyGroup?        @relation(fields: [groupId], references: [id], onDelete: SetNull)
  addresses      PartyAddress[]
  customFieldValues PartyCustomFieldValue[]
  openingBalance OpeningBalance?
  pricing        PartyPricing[]

  @@unique([businessId, phone])
  @@index([businessId, type, isActive])
  @@index([businessId, name])
  @@index([businessId, outstandingBalance])
  @@index([groupId])
}

model PartyAddress {
  id        String   @id @default(cuid())
  partyId   String
  label     String   @default("Default")
  line1     String
  line2     String?
  city      String
  state     String
  pincode   String
  type      String   @default("BILLING") // BILLING, SHIPPING
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  party Party @relation(fields: [partyId], references: [id], onDelete: Cascade)

  @@index([partyId, type])
}

model PartyGroup {
  id          String   @id @default(cuid())
  businessId  String
  name        String
  description String?
  color       String   @default("#6B7280")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Restrict)
  parties  Party[]

  @@unique([businessId, name])
  @@index([businessId])
}

model CustomFieldDefinition {
  id            String   @id @default(cuid())
  businessId    String
  name          String
  fieldType     String   // TEXT, NUMBER, DATE, DROPDOWN
  options       String[] @default([]) // for DROPDOWN type
  required      Boolean  @default(false)
  showOnInvoice Boolean  @default(false)
  entityType    String   @default("PARTY") // PARTY, PRODUCT, INVOICE
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  business      Business                @relation(fields: [businessId], references: [id], onDelete: Restrict)
  values        PartyCustomFieldValue[]
  productValues ProductCustomFieldValue[]

  @@unique([businessId, name, entityType])
  @@index([businessId, entityType])
}

model PartyCustomFieldValue {
  id        String   @id @default(cuid())
  partyId   String
  fieldId   String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  party Party                 @relation(fields: [partyId], references: [id], onDelete: Cascade)
  field CustomFieldDefinition @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@unique([partyId, fieldId])
  @@index([fieldId])
}

model OpeningBalance {
  id       String   @id @default(cuid())
  partyId  String   @unique
  amount   Int      // in paise
  type     String   // RECEIVABLE, PAYABLE
  asOfDate DateTime
  notes    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  party Party @relation(fields: [partyId], references: [id], onDelete: Cascade)
}

model PartyPricing {
  id        String   @id @default(cuid())
  partyId   String
  productId String
  price     Int      // in paise
  minQty    Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  party   Party   @relation(fields: [partyId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([partyId, productId])
  @@index([productId])
}

// === Inventory & Products ===

model Category {
  id         String   @id @default(cuid())
  businessId String
  name       String
  type       String   @default("CUSTOM") // PREDEFINED, CUSTOM
  color      String   @default("#6B7280")
  sortOrder  Int      @default(0)
  isHidden   Boolean  @default(false) // hide predefined without deleting
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([businessId, name])
  @@index([businessId])
}

model Unit {
  id         String   @id @default(cuid())
  businessId String
  name       String
  symbol     String
  type       String   @default("CUSTOM") // PREDEFINED, CUSTOM
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business        Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  products        Product[]
  conversionsFrom UnitConversion[] @relation("FromUnit")
  conversionsTo   UnitConversion[] @relation("ToUnit")

  @@unique([businessId, name])
  @@unique([businessId, symbol])
  @@index([businessId])
}

model UnitConversion {
  id         String   @id @default(cuid())
  businessId String
  fromUnitId String
  toUnitId   String
  factor     Float    // 1 fromUnit = factor toUnits
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  fromUnit Unit     @relation("FromUnit", fields: [fromUnitId], references: [id], onDelete: Restrict)
  toUnit   Unit     @relation("ToUnit", fields: [toUnitId], references: [id], onDelete: Restrict)

  @@unique([businessId, fromUnitId, toUnitId])
  @@index([businessId])
}

model Product {
  id              String    @id @default(cuid())
  businessId      String
  name            String
  sku             String?
  categoryId      String?
  unitId          String
  salePrice       Int       @default(0) // in paise
  purchasePrice   Int?      // in paise
  currentStock    Float     @default(0) // supports decimals for kg/ltr
  minStockLevel   Float     @default(0)
  stockValidation String    @default("GLOBAL") // GLOBAL, WARN_ONLY, HARD_BLOCK
  hsnCode         String?
  sacCode         String?
  description     String?
  status          String    @default("ACTIVE") // ACTIVE, INACTIVE
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  business          Business                @relation(fields: [businessId], references: [id], onDelete: Cascade)
  category          Category?               @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  unit              Unit                    @relation(fields: [unitId], references: [id], onDelete: Restrict)
  stockMovements    StockMovement[]
  customFieldValues ProductCustomFieldValue[]
  partyPricing      PartyPricing[]

  @@unique([businessId, sku])
  @@index([businessId, status])
  @@index([businessId, categoryId])
  @@index([businessId, name])
  @@index([businessId, currentStock, minStockLevel])
}

model StockMovement {
  id              String   @id @default(cuid())
  businessId      String
  productId       String
  type            String   // OPENING, SALE, PURCHASE, ADJUSTMENT_IN, ADJUSTMENT_OUT, RETURN_IN, RETURN_OUT, REVERSAL
  quantity         Float    // positive = in, negative = out
  balanceAfter    Float
  reason          String?  // DAMAGE, THEFT, AUDIT, GIFT, RETURN, OTHER
  customReason    String?
  notes           String?
  referenceType   String?  // SALE_INVOICE, PURCHASE_INVOICE, CREDIT_NOTE, DEBIT_NOTE, ADJUSTMENT
  referenceId     String?
  referenceNumber String?
  movementDate    DateTime @default(now())
  createdBy       String
  createdAt       DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  user     User     @relation(fields: [createdBy], references: [id], onDelete: Restrict)

  // Immutable — no updatedAt
  @@index([productId, createdAt])
  @@index([businessId, movementDate])
  @@index([referenceType, referenceId])
}

model ProductCustomFieldValue {
  id        String   @id @default(cuid())
  productId String
  fieldId   String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  field   CustomFieldDefinition @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@unique([productId, fieldId])
  @@index([fieldId])
}

model InventorySetting {
  id                     String   @id @default(cuid())
  businessId             String   @unique
  stockValidationMode    String   @default("WARN_ONLY") // WARN_ONLY, HARD_BLOCK
  skuPrefix              String   @default("PRD")
  skuAutoGenerate        Boolean  @default(true)
  skuNextCounter         Int      @default(1)
  lowStockAlertEnabled   Boolean  @default(true)
  lowStockAlertFrequency String   @default("DAILY") // ONCE, DAILY, EVERY_TIME
  decimalPrecisionQty    Int      @default(2)
  defaultCategoryId      String?
  defaultUnitId          String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}
