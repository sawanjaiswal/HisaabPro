generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// === Foundation models — expanded per feature via /f ===

model User {
  id            String   @id @default(cuid())
  phone         String   @unique
  name          String?
  email         String?
  passwordHash  String?
  pinHash       String?
  biometricEnabled Boolean @default(false)
  isActive      Boolean  @default(true)

  // Account lockout — Feature #64
  failedLoginAttempts Int       @default(0)
  lastFailedLoginAt   DateTime?
  accountLockedUntil  DateTime?

  // Admin suspension — Feature #7
  isSuspended        Boolean  @default(false)
  suspendedAt        DateTime?
  suspendedReason    String?

  // Referral wallet — Feature #3
  referredBy                String?
  referralBalance           Decimal  @default(0) @db.Decimal(12, 2)
  referralBalanceInReview   Decimal  @default(0) @db.Decimal(12, 2)
  referralTotalEarned       Decimal  @default(0) @db.Decimal(12, 2)
  referralFraudFlags        Int      @default(0)
  walletFrozen              Boolean  @default(false)
  lastReferralAt            DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  businessUsers  BusinessUser[]
  refreshTokens  RefreshToken[]
  stockMovements StockMovement[]
  documentsCreated Document[]   @relation("DocumentCreator")
  documentsUpdated Document[]   @relation("DocumentUpdater")
  documentsDeleted Document[]   @relation("DocumentDeleter")
  shareLogs        DocumentShareLog[]
  paymentsCreated  Payment[]    @relation("PaymentCreator")
  paymentsUpdated  Payment[]    @relation("PaymentUpdater")
  auditLogs        AuditLog[]
  appSettings      UserAppSettings?
  approvalsRequested ApprovalRequest[] @relation("ApprovalRequester")
  approvalsReviewed  ApprovalRequest[] @relation("ApprovalReviewer")

  // Referral relations
  referredByUser     User?    @relation("UserReferrals", fields: [referredBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  referredUsers      User[]   @relation("UserReferrals")
  referralCode       ReferralCode?
  referralRewardsAsReferrer ReferralReward[]     @relation("ReferralRewardsReferrer")
  referralRewardsAsReferred ReferralReward[]     @relation("ReferralRewardsReferred")
  referralEventsAsReferrer  ReferralEvent[]      @relation("ReferralEventsReferrer")
  referralEventsAsReferred  ReferralEvent[]      @relation("ReferralEventsReferred")
  referralWithdrawals       ReferralWithdrawal[]

  @@index([phone])
  @@index([referredBy])
  @@index([referralFraudFlags])
  @@index([lastReferralAt])
}

model Business {
  id            String   @id @default(cuid())
  name          String
  phone         String?
  email         String?
  address       String?
  city          String?
  state         String?
  pincode       String?
  logoUrl       String?
  businessType  String   @default("general")
  currencyCode  String   @default("INR")
  financialYearStart Int @default(4) // April
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // GST — Phase 2
  gstin              String?
  stateCode          String?  // 2-digit, extracted from GSTIN pos 0-1
  compositionScheme  Boolean  @default(false)
  eInvoiceEnabled    Boolean  @default(false)
  eWayBillEnabled    Boolean  @default(false)
  turnoverSlab       String?  // Tracks e-invoice threshold eligibility

  businessUsers    BusinessUser[]
  parties          Party[]
  partyGroups      PartyGroup[]
  customFields     CustomFieldDefinition[]
  categories       Category[]
  units            Unit[]
  products         Product[]
  unitConversions  UnitConversion[]
  stockMovements   StockMovement[]
  inventorySetting InventorySetting?
  documents        Document[]
  documentNumberSeries DocumentNumberSeries[]
  documentSettings DocumentSettings?
  digitalSignature DigitalSignature?
  termsTemplates   TermsAndConditionsTemplate[]
  payments         Payment[]
  paymentReminders PaymentReminder[]
  reminderConfig   ReminderConfig?
  roles            Role[]
  staffInvites     StaffInvite[]
  transactionLock  TransactionLockConfig?
  approvals        ApprovalRequest[]
  auditLogs        AuditLog[]
  taxCategories    TaxCategory[]
  gstReturns       GstReturn[]
  recurringInvoices RecurringInvoice[]

  @@index([name])
}

model BusinessUser {
  id         String   @id @default(cuid())
  userId     String
  businessId String
  role       String   @default("owner")
  roleId     String?
  isActive   Boolean  @default(true)
  status     String   @default("ACTIVE") // ACTIVE, SUSPENDED, PENDING
  lastActiveAt DateTime?
  joinedAt   DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  business Business @relation(fields: [businessId], references: [id], onDelete: Restrict)
  roleRef  Role?    @relation(fields: [roleId], references: [id], onDelete: SetNull)

  @@unique([userId, businessId])
  @@index([businessId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  deviceInfo String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model OtpCode {
  id        String   @id @default(cuid())
  phone     String
  code      String
  attempts  Int      @default(0)
  verified  Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([phone, verified])
  @@index([expiresAt])
}

model IdempotencyLog {
  id        String   @id @default(cuid())
  key       String   @unique
  userId    String
  response  Json
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

model Feedback {
  id         String   @id @default(cuid())
  userId     String?
  type       String   // bug, feature, general
  message    String
  rating     Int?
  screenshot String?  // base64 or URL
  metadata   Json?    // device info, page, etc.
  status     String   @default("open") // open, reviewed, resolved
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([status])
}

// === Party Management ===

model Party {
  id                String   @id @default(cuid())
  businessId        String
  name              String
  phone             String?
  email             String?
  companyName       String?
  type              String   @default("CUSTOMER") // CUSTOMER, SUPPLIER, BOTH
  groupId           String?
  tags              String[] @default([])
  gstin             String?
  stateCode         String?  // 2-digit, extracted from GSTIN pos 0-1
  gstinVerified     Boolean  @default(false)
  gstinVerifiedAt   DateTime?
  compositionScheme Boolean  @default(false)
  pan               String?
  creditLimit       Int      @default(0) // in paise, 0 = no limit
  creditLimitMode   String   @default("WARN") // WARN, BLOCK
  outstandingBalance Int     @default(0) // in paise, positive = receivable, negative = payable
  totalBusiness     Int      @default(0) // in paise, lifetime total
  lastTransactionAt DateTime?
  notes             String?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  business       Business           @relation(fields: [businessId], references: [id], onDelete: Restrict)
  group          PartyGroup?        @relation(fields: [groupId], references: [id], onDelete: SetNull)
  addresses      PartyAddress[]
  customFieldValues PartyCustomFieldValue[]
  openingBalance OpeningBalance?
  pricing        PartyPricing[]
  documents      Document[]
  payments       Payment[]
  paymentReminders PaymentReminder[]

  @@unique([businessId, phone])
  @@index([businessId, type, isActive])
  @@index([businessId, name])
  @@index([businessId, outstandingBalance])
  @@index([groupId])
}

model PartyAddress {
  id        String   @id @default(cuid())
  partyId   String
  label     String   @default("Default")
  line1     String
  line2     String?
  city      String
  state     String
  pincode   String
  type      String   @default("BILLING") // BILLING, SHIPPING
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  party Party @relation(fields: [partyId], references: [id], onDelete: Cascade)

  @@index([partyId, type])
}

model PartyGroup {
  id          String   @id @default(cuid())
  businessId  String
  name        String
  description String?
  color       String   @default("#6B7280")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Restrict)
  parties  Party[]

  @@unique([businessId, name])
  @@index([businessId])
}

model CustomFieldDefinition {
  id            String   @id @default(cuid())
  businessId    String
  name          String
  fieldType     String   // TEXT, NUMBER, DATE, DROPDOWN
  options       String[] @default([]) // for DROPDOWN type
  required      Boolean  @default(false)
  showOnInvoice Boolean  @default(false)
  entityType    String   @default("PARTY") // PARTY, PRODUCT, INVOICE
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  business      Business                @relation(fields: [businessId], references: [id], onDelete: Restrict)
  values        PartyCustomFieldValue[]
  productValues ProductCustomFieldValue[]

  @@unique([businessId, name, entityType])
  @@index([businessId, entityType])
}

model PartyCustomFieldValue {
  id        String   @id @default(cuid())
  partyId   String
  fieldId   String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  party Party                 @relation(fields: [partyId], references: [id], onDelete: Cascade)
  field CustomFieldDefinition @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@unique([partyId, fieldId])
  @@index([fieldId])
}

model OpeningBalance {
  id       String   @id @default(cuid())
  partyId  String   @unique
  amount   Int      // in paise
  type     String   // RECEIVABLE, PAYABLE
  asOfDate DateTime
  notes    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  party Party @relation(fields: [partyId], references: [id], onDelete: Cascade)
}

model PartyPricing {
  id        String   @id @default(cuid())
  partyId   String
  productId String
  price     Int      // in paise
  minQty    Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  party   Party   @relation(fields: [partyId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([partyId, productId])
  @@index([productId])
}

// === Inventory & Products ===

model Category {
  id         String   @id @default(cuid())
  businessId String
  name       String
  type       String   @default("CUSTOM") // PREDEFINED, CUSTOM
  color      String   @default("#6B7280")
  sortOrder  Int      @default(0)
  isHidden   Boolean  @default(false) // hide predefined without deleting
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([businessId, name])
  @@index([businessId])
}

model Unit {
  id         String   @id @default(cuid())
  businessId String
  name       String
  symbol     String
  type       String   @default("CUSTOM") // PREDEFINED, CUSTOM
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business        Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  products        Product[]
  conversionsFrom UnitConversion[] @relation("FromUnit")
  conversionsTo   UnitConversion[] @relation("ToUnit")

  @@unique([businessId, name])
  @@unique([businessId, symbol])
  @@index([businessId])
}

model UnitConversion {
  id         String   @id @default(cuid())
  businessId String
  fromUnitId String
  toUnitId   String
  factor     Float    // 1 fromUnit = factor toUnits
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  fromUnit Unit     @relation("FromUnit", fields: [fromUnitId], references: [id], onDelete: Restrict)
  toUnit   Unit     @relation("ToUnit", fields: [toUnitId], references: [id], onDelete: Restrict)

  @@unique([businessId, fromUnitId, toUnitId])
  @@index([businessId])
}

model Product {
  id              String    @id @default(cuid())
  businessId      String
  name            String
  sku             String?
  categoryId      String?
  unitId          String
  salePrice       Int       @default(0) // in paise
  purchasePrice   Int?      // in paise
  currentStock    Float     @default(0) // supports decimals for kg/ltr
  minStockLevel   Float     @default(0)
  stockValidation String    @default("GLOBAL") // GLOBAL, WARN_ONLY, HARD_BLOCK
  hsnCode         String?
  sacCode         String?
  taxCategoryId   String?  // FK → TaxCategory (default GST rate for this product)
  description     String?
  status          String    @default("ACTIVE") // ACTIVE, INACTIVE
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  business          Business                @relation(fields: [businessId], references: [id], onDelete: Cascade)
  category          Category?               @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  unit              Unit                    @relation(fields: [unitId], references: [id], onDelete: Restrict)
  taxCategory       TaxCategory?            @relation(fields: [taxCategoryId], references: [id], onDelete: SetNull)
  stockMovements    StockMovement[]
  customFieldValues ProductCustomFieldValue[]
  partyPricing      PartyPricing[]
  documentLineItems DocumentLineItem[]

  @@unique([businessId, sku])
  @@index([businessId, status])
  @@index([businessId, categoryId])
  @@index([businessId, name])
  @@index([businessId, currentStock, minStockLevel])
}

model StockMovement {
  id              String   @id @default(cuid())
  businessId      String
  productId       String
  type            String   // OPENING, SALE, PURCHASE, ADJUSTMENT_IN, ADJUSTMENT_OUT, RETURN_IN, RETURN_OUT, REVERSAL
  quantity         Float    // positive = in, negative = out
  balanceAfter    Float
  reason          String?  // DAMAGE, THEFT, AUDIT, GIFT, RETURN, OTHER
  customReason    String?
  notes           String?
  referenceType   String?  // SALE_INVOICE, PURCHASE_INVOICE, CREDIT_NOTE, DEBIT_NOTE, ADJUSTMENT
  referenceId     String?
  referenceNumber String?
  movementDate    DateTime @default(now())
  createdBy       String
  createdAt       DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  user     User     @relation(fields: [createdBy], references: [id], onDelete: Restrict)

  // Immutable — no updatedAt
  @@index([productId, createdAt])
  @@index([businessId, movementDate])
  @@index([referenceType, referenceId])
}

model ProductCustomFieldValue {
  id        String   @id @default(cuid())
  productId String
  fieldId   String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  field   CustomFieldDefinition @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@unique([productId, fieldId])
  @@index([fieldId])
}

model InventorySetting {
  id                     String   @id @default(cuid())
  businessId             String   @unique
  stockValidationMode    String   @default("WARN_ONLY") // WARN_ONLY, HARD_BLOCK
  skuPrefix              String   @default("PRD")
  skuAutoGenerate        Boolean  @default(true)
  skuNextCounter         Int      @default(1)
  lowStockAlertEnabled   Boolean  @default(true)
  lowStockAlertFrequency String   @default("DAILY") // ONCE, DAILY, EVERY_TIME
  decimalPrecisionQty    Int      @default(2)
  defaultCategoryId      String?
  defaultUnitId          String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

// === Invoicing & Documents ===

model Document {
  id                     String   @id @default(cuid())
  businessId             String
  type                   String   // SALE_INVOICE, PURCHASE_INVOICE, ESTIMATE, PROFORMA, SALE_ORDER, PURCHASE_ORDER, DELIVERY_CHALLAN
  status                 String   @default("DRAFT") // DRAFT, SAVED, SHARED, CONVERTED, DELETED

  // Numbering
  documentNumber         String?  // Assigned on SAVE, null for DRAFT
  sequenceNumber         Int?
  financialYear          String?  // "2526" (April 2025 - March 2026)

  // Party
  partyId                String
  shippingAddressId      String?

  // Dates
  documentDate           DateTime
  dueDate                DateTime?
  paymentTerms           String?  // COD, NET_7, NET_15, NET_30, NET_60, NET_90, CUSTOM

  // Totals (PAISE — integer)
  subtotal               Int      @default(0)
  totalDiscount          Int      @default(0)
  totalAdditionalCharges Int      @default(0)
  roundOff               Int      @default(0)
  grandTotal             Int      @default(0)

  // GST — Phase 2
  placeOfSupply          String?  // 2-digit state code
  supplyType             String   @default("B2B") // B2B, B2C_LARGE, B2C_SMALL, EXPORT, SEZ
  isReverseCharge        Boolean  @default(false)
  isComposite            Boolean  @default(false)
  totalTaxableValue      Int      @default(0) // paise — sum of line taxableValues
  totalCgst              Int      @default(0) // paise
  totalSgst              Int      @default(0) // paise
  totalIgst              Int      @default(0) // paise
  totalCess              Int      @default(0) // paise

  // TDS/TCS — Phase 2B (B2B invoice deductions)
  tdsRate                Int      @default(0) // basis points
  tdsAmount              Int      @default(0) // paise
  tcsRate                Int      @default(0) // basis points
  tcsAmount              Int      @default(0) // paise

  // Profit
  totalCost              Int      @default(0)
  totalProfit            Int      @default(0)
  profitPercent          Float    @default(0)

  // Content
  notes                  String?  @db.Text
  termsAndConditions     String?  @db.Text
  includeSignature       Boolean  @default(false)

  // Transport (Delivery Challan)
  vehicleNumber          String?
  driverName             String?
  transportNotes         String?

  // Conversion chain
  sourceDocumentId       String?  @unique
  sourceDocument         Document? @relation("DocumentConversion", fields: [sourceDocumentId], references: [id], onDelete: SetNull)
  convertedTo            Document? @relation("DocumentConversion")

  // Payment tracking (denormalized from payments)
  paidAmount             Int      @default(0)
  balanceDue             Int      @default(0)

  // Recycle bin
  deletedAt              DateTime?
  deletedBy              String?
  permanentDeleteAt      DateTime?

  // Audit
  createdBy              String
  updatedBy              String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  // Offline sync
  clientId               String?  @unique

  // Relations
  business               Business          @relation(fields: [businessId], references: [id], onDelete: Restrict)
  party                  Party             @relation(fields: [partyId], references: [id], onDelete: Restrict)
  creator                User              @relation("DocumentCreator", fields: [createdBy], references: [id], onDelete: Restrict)
  updater                User?             @relation("DocumentUpdater", fields: [updatedBy], references: [id])
  deleter                User?             @relation("DocumentDeleter", fields: [deletedBy], references: [id])
  // E-Compliance — Phase 2
  eInvoice               EInvoice?
  eWayBill               EWayBill?

  // Recurring — Phase 2
  recurringInvoiceId     String?
  recurringInvoice       RecurringInvoice? @relation(fields: [recurringInvoiceId], references: [id], onDelete: SetNull)

  // Credit/Debit Note link
  originalDocumentId     String?
  creditDebitReason      String?  @db.VarChar(500)
  originalDocument       Document?  @relation("CreditDebitLink", fields: [originalDocumentId], references: [id], onDelete: SetNull)
  creditDebitNotes       Document[] @relation("CreditDebitLink")

  lineItems              DocumentLineItem[]
  additionalCharges      DocumentAdditionalCharge[]
  shareLogs              DocumentShareLog[]
  paymentAllocations     PaymentAllocation[]
  paymentReminders       PaymentReminder[]

  @@unique([businessId, type, documentNumber])
  @@index([businessId, type, status])
  @@index([businessId, partyId])
  @@index([businessId, documentDate])
  @@index([permanentDeleteAt])
  @@index([clientId])
  @@index([recurringInvoiceId])
  @@index([originalDocumentId])
}

model DocumentLineItem {
  id             String   @id @default(cuid())
  documentId     String
  productId      String
  sortOrder      Int      @default(0)

  quantity       Float    // supports decimals (kg/ltr)
  rate           Int      // PAISE
  discountType   String   @default("AMOUNT") // AMOUNT, PERCENTAGE
  discountValue  Int      @default(0) // paise for AMOUNT, basis points (x100) for PERCENTAGE
  discountAmount Int      @default(0) // calculated paise
  lineTotal      Int      @default(0) // (qty * rate) - discountAmount

  // GST — Phase 2 (all amounts in PAISE, rates in BASIS POINTS)
  taxCategoryId  String?
  hsnCode        String?
  sacCode        String?
  taxableValue   Int      @default(0) // paise — equals lineTotal (taxable amount after discount)
  cgstRate       Int      @default(0) // basis points (e.g. 900 = 9%)
  cgstAmount     Int      @default(0) // paise
  sgstRate       Int      @default(0) // basis points
  sgstAmount     Int      @default(0) // paise
  igstRate       Int      @default(0) // basis points (e.g. 1800 = 18%)
  igstAmount     Int      @default(0) // paise
  cessRate       Int      @default(0) // basis points
  cessAmount     Int      @default(0) // paise

  // Snapshot at time of invoice
  purchasePrice  Int      @default(0)
  profit         Int      @default(0)
  profitPercent  Float    @default(0)

  // Stock snapshot
  stockBefore    Float    @default(0)
  stockAfter     Float    @default(0)

  document  Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([documentId])
  @@index([productId])
}

model DocumentAdditionalCharge {
  id         String   @id @default(cuid())
  documentId String
  name       String
  type       String   @default("FIXED") // FIXED, PERCENTAGE
  value      Int      @default(0) // paise for FIXED, basis points for PERCENTAGE
  amount     Int      @default(0) // calculated paise
  sortOrder  Int      @default(0)

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
}

model DocumentShareLog {
  id             String   @id @default(cuid())
  documentId     String
  channel        String   // WHATSAPP, EMAIL, PRINT
  format         String   // PDF, JPG, PNG
  recipientPhone String?
  recipientEmail String?
  fileUrl        String?
  fileSize       Int?
  message        String?  @db.Text
  sentBy         String
  sentAt         DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [sentBy], references: [id], onDelete: Restrict)

  @@index([documentId])
}

model DocumentNumberSeries {
  id              String   @id @default(cuid())
  businessId      String
  documentType    String   // SALE_INVOICE, PURCHASE_INVOICE, etc.
  financialYear   String   // "2526"

  prefix          String   @default("INV")
  suffix          String   @default("")
  separator       String   @default("-")
  paddingDigits   Int      @default(3)
  currentSequence Int      @default(0)
  startingNumber  Int      @default(1)
  resetOnNewYear  Boolean  @default(true)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, documentType, financialYear])
}

model DigitalSignature {
  id         String   @id @default(cuid())
  businessId String   @unique
  imageUrl   String
  autoApply  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model TermsAndConditionsTemplate {
  id         String   @id @default(cuid())
  businessId String
  name       String
  content    String   @db.Text
  isDefault  Boolean  @default(false)
  appliesTo  String[] @default([]) // Document types this applies to
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, name])
  @@index([businessId])
}

model DocumentSettings {
  id                        String   @id @default(cuid())
  businessId                String   @unique
  defaultPaymentTerms       String   @default("COD")
  roundOffTo                String   @default("NEAREST_1") // NONE, NEAREST_1, NEAREST_050, NEAREST_010
  showProfitDuringBilling   Boolean  @default(true)
  allowFutureDates          Boolean  @default(false)
  transactionLockDays       Int      @default(0)
  recycleBinRetentionDays   Int      @default(30)
  autoShareOnSave           Boolean  @default(false)
  autoShareChannel          String   @default("WHATSAPP")
  autoShareFormat           String   @default("PDF")
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

// === Payment Tracking ===

model Payment {
  id              String    @id @default(cuid())
  offlineId       String?   @unique
  businessId      String
  type            String    // PAYMENT_IN, PAYMENT_OUT
  partyId         String
  amount          Int       // paise
  date            DateTime
  mode            String    // CASH, UPI, BANK_TRANSFER, CHEQUE, NEFT_RTGS_IMPS, CREDIT_CARD, OTHER
  referenceNumber String?   @db.VarChar(100)
  notes           String?   @db.VarChar(500)
  isDeleted       Boolean   @default(false)
  deletedAt       DateTime?
  createdBy       String
  updatedBy       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  business     Business            @relation(fields: [businessId], references: [id], onDelete: Restrict)
  party        Party               @relation(fields: [partyId], references: [id], onDelete: Restrict)
  creator      User                @relation("PaymentCreator", fields: [createdBy], references: [id], onDelete: Restrict)
  updater      User?               @relation("PaymentUpdater", fields: [updatedBy], references: [id])
  allocations  PaymentAllocation[]
  discount     PaymentDiscount?

  @@index([businessId, date])
  @@index([businessId, partyId])
  @@index([businessId, type])
  @@index([businessId, mode])
  @@index([businessId, isDeleted])
}

model PaymentAllocation {
  id         String   @id @default(cuid())
  paymentId  String
  invoiceId  String
  amount     Int      // paise
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  payment  Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  invoice  Document @relation(fields: [invoiceId], references: [id], onDelete: Restrict)

  @@unique([paymentId, invoiceId])
  @@index([invoiceId])
}

model PaymentDiscount {
  id               String   @id @default(cuid())
  paymentId        String   @unique
  type             String   // PERCENTAGE, FIXED
  value            Float    // percentage value or fixed paise
  calculatedAmount Int      // paise
  reason           String?  @db.VarChar(200)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
}

model PaymentReminder {
  id            String    @id @default(cuid())
  businessId    String
  partyId       String
  invoiceId     String?
  channel       String    // WHATSAPP, SMS, PUSH
  status        String    @default("SCHEDULED")
  message       String    @db.Text
  scheduledAt   DateTime?
  sentAt        DateTime?
  failureReason String?   @db.VarChar(500)
  retryCount    Int       @default(0)
  isAutomatic   Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  business Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  party    Party     @relation(fields: [partyId], references: [id], onDelete: Restrict)
  invoice  Document? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([businessId, status])
  @@index([businessId, partyId])
  @@index([scheduledAt, status])
}

model ReminderConfig {
  id                      String   @id @default(cuid())
  businessId              String   @unique
  enabled                 Boolean  @default(true)
  autoRemindEnabled       Boolean  @default(false)
  frequencyDays           Int[]    @default([1, 3, 7])
  maxRemindersPerInvoice  Int      @default(5)
  defaultChannel          String   @default("WHATSAPP")
  quietHoursStart         String   @default("21:00")
  quietHoursEnd           String   @default("09:00")
  whatsappTemplate        String?  @db.Text
  smsTemplate             String?  @db.Text
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

// === Settings & Security ===

model Role {
  id          String   @id @default(cuid())
  businessId  String
  name        String
  description String?
  isSystem    Boolean  @default(false)
  isDefault   Boolean  @default(false)
  priority    Int      @default(0)
  permissions String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business     Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  businessUsers BusinessUser[]

  @@unique([businessId, name])
  @@index([businessId])
}

model StaffInvite {
  id         String   @id @default(cuid())
  businessId String
  name       String
  phone      String
  roleId     String
  code       String   @unique
  status     String   @default("PENDING") // PENDING, ACCEPTED, EXPIRED
  expiresAt  DateTime
  invitedBy  String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([phone])
  @@index([code])
}

model TransactionLockConfig {
  id                          String   @id @default(cuid())
  businessId                  String   @unique
  lockAfterDays               Int?
  requireApprovalForEdit      Boolean  @default(false)
  requireApprovalForDelete    Boolean  @default(false)
  priceChangeThresholdPercent Float?
  discountThresholdPercent    Float?
  operationPinHash            String?
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model ApprovalRequest {
  id               String    @id @default(cuid())
  businessId       String
  type             String    // EDIT_LOCKED_TRANSACTION, DELETE_TRANSACTION, PRICE_OVERRIDE, DISCOUNT_OVERRIDE
  entityType       String
  entityId         String
  requestedBy      String
  requestedChanges Json
  status           String    @default("PENDING") // PENDING, APPROVED, DENIED, EXPIRED
  reviewedBy       String?
  reviewedAt       DateTime?
  reviewNote       String?
  expiresAt        DateTime
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  business  Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  requester User     @relation("ApprovalRequester", fields: [requestedBy], references: [id], onDelete: Restrict)
  reviewer  User?    @relation("ApprovalReviewer", fields: [reviewedBy], references: [id])

  @@index([businessId, status])
  @@index([requestedBy])
}

model AuditLog {
  id          String   @id @default(cuid())
  businessId  String
  action      String   // CREATE, UPDATE, DELETE, RESTORE, LOCK_OVERRIDE, PIN_RESET, ROLE_CHANGE, APPROVAL_REQUEST, APPROVAL_RESPONSE
  entityType  String
  entityId    String
  entityLabel String?
  userId      String
  changes     Json?
  reason      String?
  ipAddress   String?
  deviceInfo  String?
  createdAt   DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Restrict)

  // Immutable — no updatedAt
  @@index([businessId, createdAt])
  @@index([businessId, entityType])
  @@index([userId])
}

// === Referral & Earn — Feature #3 ===

model ReferralCode {
  id                String   @id @default(cuid())
  userId            String   @unique
  code              String   @unique
  link              String
  totalReferrals    Int      @default(0)
  successfulRewards Int      @default(0)
  totalEarned       Decimal  @default(0) @db.Decimal(12, 2)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([code])
  @@index([userId])
}

model ReferralEvent {
  id                String   @id @default(cuid())
  referrerId        String
  referredId        String
  eventType         String   // signup, payment_success, refund_issued, reward_credited
  eventData         Json?
  ipAddress         String?
  deviceFingerprint String?
  userAgent         String?
  isSuspicious      Boolean  @default(false)
  suspiciousReason  String?
  createdAt         DateTime @default(now())

  referrer User @relation("ReferralEventsReferrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referred User @relation("ReferralEventsReferred", fields: [referredId], references: [id], onDelete: Cascade)

  // Immutable — no updatedAt
  @@index([referrerId, eventType])
  @@index([referredId, eventType])
  @@index([referrerId, isSuspicious])
  @@index([isSuspicious, createdAt])
  @@index([createdAt])
}

model ReferralReward {
  id             String    @id @default(cuid())
  referrerId     String
  referredId     String
  amount         Decimal   @db.Decimal(10, 2)
  status         String    // in_review, approved, withdrawn, clawed_back
  eligibleAt     DateTime?
  approvedAt     DateTime?
  withdrawnAt    DateTime?
  clawedBackAt   DateTime?
  clawBackReason String?
  withdrawalId   String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  referrer   User                @relation("ReferralRewardsReferrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referred   User                @relation("ReferralRewardsReferred", fields: [referredId], references: [id], onDelete: Cascade)
  withdrawal ReferralWithdrawal? @relation(fields: [withdrawalId], references: [id])

  @@index([referrerId, status])
  @@index([status, eligibleAt])
}

model ReferralWithdrawal {
  id            String    @id @default(cuid())
  userId        String
  amount        Decimal   @db.Decimal(10, 2)
  upiId         String
  status        String    // pending, approved, rejected, failed, processing
  statusReason  String?
  autoApproved  Boolean   @default(false)
  approvedBy    String?
  approvedAt    DateTime?
  processedAt   DateTime?
  transactionId String?
  failureReason String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  rewards ReferralReward[]

  @@index([userId, status])
  @@index([status, createdAt])
}

model UserAppSettings {
  id                  String   @id @default(cuid())
  userId              String   @unique
  dateFormat          String   @default("DD/MM/YYYY")
  pinEnabled          Boolean  @default(false)
  pinHash             String?
  pinAttempts         Int      @default(0)
  pinLockedUntil      DateTime?
  biometricEnabled    Boolean  @default(false)
  calculatorPosition  String   @default("BOTTOM_RIGHT")
  language            String   @default("en")
  theme               String   @default("light")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// === Admin Panel ===

enum AdminRole {
  ADMIN
  SUPER_ADMIN
}

/// Platform admin accounts — separate from regular User table
model AdminUser {
  id                   String    @id @default(cuid())
  email                String    @unique
  passwordHash         String
  name                 String
  role                 AdminRole @default(ADMIN)
  isActive             Boolean   @default(true)
  twoFactorEnabled     Boolean   @default(false)
  twoFactorSecret      String?   // TOTP secret (encrypted at rest)

  // Security tracking
  lastLoginAt          DateTime?
  failedLoginAttempts  Int       @default(0)
  accountLockedUntil   DateTime?
  lastFailedLoginAt    DateTime?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  actions    AdminAction[]

  @@index([email])
  @@index([role, isActive])
}

/// Immutable audit trail — every admin action is recorded here
model AdminAction {
  id          String   @id @default(cuid())
  adminId     String
  action      String   // SUSPEND_USER, UNSUSPEND_USER, VIEW_USER, UPDATE_SETTINGS, LOGIN, LOGOUT
  targetType  String?  // USER, BUSINESS, SETTINGS
  targetId    String?
  metadata    Json     @default("{}")
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  admin AdminUser @relation(fields: [adminId], references: [id], onDelete: Restrict)

  // Immutable — no updatedAt
  @@index([adminId, createdAt])
  @@index([targetType, targetId])
  @@index([createdAt])
}

/// User suspension records — tracks who suspended whom and why
model UserSuspension {
  id          String    @id @default(cuid())
  userId      String    @unique
  suspendedBy String    // AdminUser.id
  reason      String
  notes       String?
  suspendedAt DateTime  @default(now())
  liftedAt    DateTime?
  liftedBy    String?   // AdminUser.id
  liftNotes   String?

  @@index([userId])
  @@index([suspendedBy])
}

// ═══════════════════════════════════════════════════════════════════════════════
// Phase 2 — GST & Compliance
// ═══════════════════════════════════════════════════════════════════════════════

/// Tax rate category — "GST 18%", "GST 5%", "Exempt", etc.
model TaxCategory {
  id           String   @id @default(cuid())
  businessId   String
  name         String   // "GST 18%", "GST 5%", "Exempt"
  rate         Int      @default(0)  // basis points (1800 = 18.00%)
  cessRate     Int      @default(0)  // basis points for additional cess
  cessType     String   @default("PERCENTAGE") // PERCENTAGE, FIXED_PER_UNIT
  hsnCode      String?  // Default HSN for this category
  sacCode      String?  // Default SAC for this category
  isDefault    Boolean  @default(false) // System-created defaults (0%, 5%, 12%, 18%, 28%)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  business Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([businessId, name])
  @@index([businessId, isActive])
}

/// Pre-seeded HSN/SAC code database (~12K records, read-only)
model HsnCode {
  code           String  @id // 4-8 digit HSN code
  description    String
  chapter        String? // 2-digit chapter (first 2 digits)
  defaultRate    Int     @default(0) // basis points — default GST rate
  cessApplicable Boolean @default(false)
  cessRate       Int     @default(0) // basis points

  @@index([chapter])
  @@index([description])
}

/// E-Invoice record — IRN + QR from NIC IRP portal
model EInvoice {
  id             String   @id @default(cuid())
  documentId     String   @unique
  irn            String   @unique // 64-char hash from NIC
  ackNumber      String   // Acknowledgement number
  ackDate        DateTime
  qrCodeData     String   @db.Text // Base64 or raw QR data
  signedInvoice  Json     // Full signed invoice JSON from NIC
  status         String   @default("GENERATED") // GENERATED, CANCELLED
  cancelReason   String?
  cancelledAt    DateTime?
  rawResponse    Json?    // Full NIC response for debugging
  createdAt      DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Restrict)

  @@index([status])
}

/// E-Way Bill record
model EWayBill {
  id              String   @id @default(cuid())
  documentId      String   @unique
  ewbNumber       String   @unique
  ewbDate         DateTime
  validUpto       DateTime
  transportMode   String   @default("ROAD") // ROAD, RAIL, AIR, SHIP
  transporterId   String?
  transporterName String?
  vehicleNumber   String?
  vehicleType     String?  // REGULAR, ODC (over-dimensional cargo)
  distance        Int      @default(0) // kilometers
  fromPincode     String
  toPincode       String
  status          String   @default("ACTIVE") // ACTIVE, CANCELLED, EXTENDED
  cancelReason    String?
  cancelledAt     DateTime?
  partBUpdates    Json     @default("[]") // Array of vehicle change records
  createdAt       DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Restrict)

  @@index([documentId])
  @@index([status])
  @@index([ewbNumber])
}

/// GST return filing tracker
model GstReturn {
  id                String   @id @default(cuid())
  businessId        String
  period            String   // "2026-01" (YYYY-MM)
  returnType        String   // GSTR1, GSTR3B, GSTR9
  status            String   @default("DRAFT") // DRAFT, EXPORTED, FILED
  filedAt           DateTime?
  jsonData          Json?    // Exported JSON data
  summary           Json?    // Aggregated summary (tax totals, counts)
  invoiceCount      Int      @default(0)
  totalTaxableValue Int      @default(0) // paise
  totalTax          Int      @default(0) // paise
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, period, returnType])
  @@index([businessId, returnType])
}

/// Recurring invoice template — auto-generates invoices on schedule
model RecurringInvoice {
  id                  String    @id @default(cuid())
  businessId          String
  templateDocumentId  String    // Source document used as template
  partyId             String
  frequency           String    // WEEKLY, MONTHLY, QUARTERLY, YEARLY
  startDate           DateTime
  endDate             DateTime?
  nextRunDate         DateTime
  dayOfMonth          Int?      // 1-28 for MONTHLY
  dayOfWeek           Int?      // 0-6 for WEEKLY (0 = Sunday)
  autoSend            Boolean   @default(false)
  status              String    @default("ACTIVE") // ACTIVE, PAUSED, COMPLETED
  generatedCount      Int       @default(0)
  lastGeneratedAt     DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  business  Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  documents Document[]

  @@index([businessId, status])
  @@index([nextRunDate, status])
}
