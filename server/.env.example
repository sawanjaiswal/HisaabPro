# =============================================================================
# HisaabPro — Backend Environment Variables
# Copy to .env and fill in values
# =============================================================================

# --- Database (Neon PostgreSQL) ---
DATABASE_URL=postgresql://user:password@localhost:5432/hisaabpro?sslmode=require

# --- Auth / JWT ---
JWT_SECRET=change-me-to-a-random-256-bit-secret
JWT_REFRESH_SECRET=change-me-to-a-different-random-secret

# --- Encryption (for sensitive fields at rest) ---
ENCRYPTION_KEY=change-me-32-byte-hex-key

# --- App Config ---
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:5173
LOG_LEVEL=info

# --- Payments (Razorpay) ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Razorpay Plan IDs (create in Razorpay Dashboard → Subscriptions → Plans)
RAZORPAY_PLAN_FREE=
RAZORPAY_PLAN_PRO=
RAZORPAY_PLAN_BUSINESS=

# --- Email (Resend) ---
# API key from https://resend.com/api-keys — required for email notifications
RESEND_API_KEY=
# From address for outgoing emails (format: "Name <email>")
RESEND_FROM_EMAIL=HisaabPro <noreply@hisaabpro.in>

# --- WhatsApp (Aisensy) ---
# API key from https://aisensy.com — required for WhatsApp template messages
AISENSY_API_KEY=

# --- Push Notifications (Firebase Cloud Messaging) ---
# Service account JSON from Firebase Console > Project Settings > Service Accounts
# Paste the entire JSON as a single-line string (no newlines)
# Required for push notifications to mobile devices
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"...",...}

# --- SMS / OTP (MSG91) ---
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=

# --- Bot Protection (Cloudflare Turnstile) ---
TURNSTILE_SECRET_KEY=

# --- Rate Limiting (optional — Redis for distributed) ---
# REDIS_URL=redis://localhost:6379

# --- Referral System ---
FRONTEND_URL=http://localhost:5173
REFERRAL_REWARD_AMOUNT=100
REFERRAL_REVIEW_WINDOW_DAYS=7

# --- Password Hashing ---
# BCRYPT_SALT_ROUNDS=12
