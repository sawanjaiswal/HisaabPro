}

// Delivery History Types
export interface DeliveryHistoryResponse {
  customerId: string;
  customerName: string;
  weekStart: string;
  weekEnd: string;
  weekSummary: {
    totalLitres: number;
    totalAmount: number;
    totalDays: number;
    paidDays: number;
    unpaidDays: number;
  };
  dailyData: DailyData[];
}

export interface DailyData {
  date: string;
  dayOfWeek: number;
  shifts: {
    morning: ShiftData;
    evening: ShiftData;
  };
  dayTotal: { quantity: number; amount: number };
  payment: {
    isPaid: boolean;
    paidAmount: number;
    paymentId?: string;
