import type { DeliveryStatus } from '@shared/stats/enums';

/** SSOT for customer/supplier entity discrimination */
export type EntityType = 'customer' | 'supplier';

export interface User {
  id: string;
  phone: string;
  name?: string;
  email?: string | null;
  emailVerified?: boolean;
  isVerified: boolean;
  avatarUrl?: string | null;
  upiBusinessName?: string | null;
  defaultCowRate?: number | null;
  defaultBuffaloRate?: number | null;
  customerReferralRewardAmount?: number | null;
  createdAt?: string;
  updatedAt?: string;
}

export interface AuthResponse {
  success: boolean;
  message: string;
  user?: User;
  tokens?: {
    accessToken: string;
    refreshToken: string;
  };
}

export interface Customer {
  id: string;
  name: string;
  phone: string;
  address?: string;
  sellRate?: number;  // Legacy single rate (backward compatible)
  rate?: number;      // Display rate (resolved from sellRate/cowRate/buffaloRate for UI)
  cowRate?: number;    // Rate for cow milk
  buffaloRate?: number; // Rate for buffalo milk
  defaultQuantity?: number;
  billingCycle?: 'WEEKLY' | 'MONTHLY' | 'TEN_DAYS' | 'FIFTEEN_DAYS' | 'CUSTOM';
  billingStartDay?: number; // 0-6 for Sunday-Saturday
  customBillingDays?: number;
  nextBillingDate?: string; // YYYY-MM-DD
  outstandingBalance: number;
  isArchived: boolean;
  latitude?: number | null;
  longitude?: number | null;
  locationAddress?: string | null;
  locationAccuracy?: number | null;
  locationCapturedAt?: string | null;
  locationSource?: string | null;
  deliveryOrder?: number | null;
  revision?: number;
  createdAt: string;
  updatedAt: string;
  // Referral system
  referredById?: string | null;
  referredBy?: { id: string; name: string; phone: string } | null;
  referrals?: { id: string; name: string }[];
  _count?: { referrals?: number; Referrals?: number; MilkOutEntry?: number; Payment?: number; ProductEntry?: number };
  isLocked?: boolean;
  lockedAt?: string | null;
  // Portal sharing
  portalToken?: string | null;
  portalSmsStatus?: 'unsent' | 'sent' | 'failed';
  // Optional nested relations (only included when fetched with getById)
  MilkOutEntry?: MilkOutEntry[];
  Payment?: Payment[];
  ProductEntry?: ProductEntry[];
}

export interface SupplierCenter {
  id: string;
  name: string;
  address?: string;
  location?: string;
  phone?: string;
  createdAt: string;
  updatedAt: string;
}

export type RateType = 'FIXED' | 'FAT_BASED';

export interface Supplier {
  id: string;
  name: string;
  phone: string;
  address?: string;
  purchaseRate?: number; // Legacy single rate (backward compatible)
  cowRate?: number;       // Rate for cow milk
  buffaloRate?: number;   // Rate for buffalo milk
  outstandingBalance: number;
  isPinned: boolean;
  isArchived: boolean;
  centerId?: string | null;
  center?: SupplierCenter | null;
  // Quality-based pricing (Phase 2.5)
  rateType: RateType;             // Pricing model (legacy, global)
  baseFatPercent?: number;        // Base FAT % for calculation (legacy)
  fatRateAdjustment?: number;     // ₹ adjustment per 1% FAT (legacy)
  // Per-milk-type pricing (new)
  cowRateType?: RateType;         // FIXED or FAT_BASED for cow
  buffaloRateType?: RateType;     // FIXED or FAT_BASED for buffalo
  cowFatPercent?: number;         // FAT% for cow (e.g., 6.0)
  cowRatePerFat?: number;         // ₹/FAT for cow (e.g., 9.5)
  buffaloFatPercent?: number;     // FAT% for buffalo (e.g., 6.0)
  buffaloRatePerFat?: number;     // ₹/FAT for buffalo (e.g., 11.5)
  // Portal sharing
  portalToken?: string | null;
  portalSmsStatus?: 'unsent' | 'sent' | 'failed';
  // Relations (populated when fetching by ID)
  MilkInEntry?: MilkInEntry[];    // Recent milk purchases
  Payment?: Payment[];             // Recent payments to supplier
  _count?: { MilkInEntry?: number; Payment?: number };
  _milkStats?: { avgFat: number | null; avgSnf: number | null; avgClr: number | null; totalQuantity: number };
  createdAt: string;
  updatedAt: string;
}

export type ProductCategory = 'DAIRY' | 'BEVERAGES' | 'SNACKS' | 'OTHERS';

export interface Product {
  id: string;
  name: string;
  unit: 'kg' | 'L' | 'piece';
  price: number;
  icon: string;
  category: ProductCategory;
  isActive: boolean;
  isArchived: boolean;
  createdAt: string;
  updatedAt: string;
}

export interface ProductEntry {
  id: string;
  customerId: string;
  customer?: {
    id: string;
    name: string;
    phone: string;
    outstandingBalance: number;
  };
  productId: string;
  product?: {
    id: string;
    name: string;
    unit: string;
    price: number;
    icon: string;
  };
  date: string; // YYYY-MM-DD
  quantity: number;
  price: number;
  totalCost: number;
  unit: string;
  status: 'pending' | 'confirmed' | 'delivered' | 'cancelled';
  deliveredAt?: string;
  reminderSet: boolean;
  reminderSentAt?: string;
  billedAt?: string;
  createdAt: string;
  updatedAt: string;
}

export interface SupplierProduct {
  id: string;
  name: string;
  unit: 'kg' | 'L' | 'piece';
  price: number;
  icon: string;
  category: ProductCategory;
  isActive: boolean;
  isArchived: boolean;
  createdAt: string;
  updatedAt: string;
}

export interface SupplierProductEntry {
  id: string;
  supplierId: string;
  supplier?: {
    id: string;
    name: string;
    phone: string;
    outstandingBalance: number;
  };
  supplierProductId: string;
  supplierProduct?: {
    id: string;
    name: string;
    unit: string;
    price: number;
    icon: string;
  };
  date: string;
  quantity: number;
  price: number;
  totalCost: number;
  unit: string;
  note?: string;
  createdAt: string;
  updatedAt: string;
}

export interface MilkOutEntry {
  id: string;
  customerId: string;
  customer?: {
    name: string;
    phone: string;
  };
  date: string;
  quantity: number;
  sellRate?: number;
  totalRevenue?: number;
  milkType?: 'COW' | 'BUFFALO';
  session?: 'MORNING' | 'EVENING';
  wasSkipped: boolean;
  note?: string;
  createdAt?: string;
  updatedAt?: string;
}

export interface MilkInEntry {
  id: string;
  supplierId: string;
  supplier?: {
    name: string;
    phone: string;
  };
  date: string;
  quantity: number;
  purchaseRate: number;
  totalCost: number;
  milkType?: 'COW' | 'BUFFALO';
  session?: 'MORNING' | 'EVENING';
  note?: string;
  // Quality metrics (Phase 2.5)
  fatPercent?: number;     // FAT % (2.5-15.0)
  snfPercent?: number;     // SNF % (7.0-10.0)
  clrPercent?: number;     // CLR (20-40)
  calculatedRate?: number; // Actual rate used (FAT-based)
  rateType?: RateType;     // How rate was calculated
  createdAt: string;
  updatedAt: string;
}

export interface Payment {
  id: string;
  entityType: EntityType;
  entityId: string;
  customerId?: string;
  customer?: {
    name: string;
    phone: string;
    outstandingBalance?: number;
  };
  supplierId?: string;
  supplier?: {
    name: string;
    phone: string;
    outstandingBalance?: number;
  };
  amount: number;
  date: string;
  mode: 'cash' | 'upi' | 'bank' | 'other';
  direction: 'received' | 'paid';
  note?: string;
  proofImageUrl?: string;
  upiTransactionId?: string;
  revision?: number;
  createdAt: string;
  updatedAt: string;
}

export interface Holiday {
  id: string;
  customerId: string;
  customer?: {
    id: string;
    name: string;
    phone: string;
  };
  startDate: string; // YYYY-MM-DD
  endDate: string; // YYYY-MM-DD
  note?: string;
  createdAt: string;
  updatedAt: string;
}

export type ShiftSession = 'MORNING' | 'EVENING';

export interface MilkmanHoliday {
  id: string;
  userId: string;
  startDate: string;  // YYYY-MM-DD
  startShift: ShiftSession;
  endDate: string;    // YYYY-MM-DD
  endShift: ShiftSession;
  reason?: string | null;
  createdAt: string;
  updatedAt: string;
}

export interface MilkmanHolidayCheck {
  onHoliday: boolean;
  holiday?: {
    id: string;
    reason: string | null;
  };
}

export interface DashboardSummary {
  milkIn: {
    quantity: number;
    cost: number;
  };
  milkOut: {
    quantity: number;
    revenue: number;
  };
  profit: number;
  cashflow: {
    received: number;
    paid: number;
    net: number;
  };
  deliveredCount?: number;
  skippedCount?: number;
}

export interface MonthlyAnalytics {
  month: string;
  milkIn: {
    quantity: number;
    cost: number;
  };
  milkOut: {
    quantity: number;
    revenue: number;
  };
  profit: number;
  paymentsReceived: number;
  topCustomers: Array<{
    name: string;
    quantity: number;
    revenue: number;
  }>;
}

export interface BusinessStats {
  customers: {
    total: number;
    active: number;
  };
  suppliers: {
    total: number;
    active: number;
  };
  balances: {
    totalReceivable: number;
    totalPayable: number;
    netPosition: number;
  };
}

// Reconciliation Report Types
export interface ReconciliationReport {
  summary: {
    totalDeliveryValue: number;
    totalPaymentsReceived: number;
    netOutstanding: number;
    customersCount: number;
    customersWithDiscrepancies: number;
  };
  customers: CustomerReconciliation[];
}

export interface CustomerReconciliation {
  customerId: string;
  customerName: string;
  customerPhone: string;
  deliveries: {
    milkCount: number;
    milkValue: number;
    productsCount: number;
    productsValue: number;
    totalValue: number;
  };
  payments: {
    count: number;
    totalAmount: number;
  };
  reconciliation: {
    difference: number;
    status: 'balanced' | 'outstanding' | 'overpaid';
    discrepancyPercentage: number;
  };
}

