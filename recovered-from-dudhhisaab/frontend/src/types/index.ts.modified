}

export interface ShiftData {
  cow: { quantity: number; rate: number; amount: number };
  buffalo: { quantity: number; rate: number; amount: number };
}

// Subscription & Pricing Types
export type SubscriptionTier = 'free' | 'pro' | 'pro_max' | 'business';
export type SubscriptionDuration = 'monthly' | 'quarterly' | 'yearly' | 'lifetime';
export type SubscriptionStatus = 'active' | 'cancelled' | 'expired' | 'pending' | 'halted' | 'paused';
export type TransactionType = 'PURCHASE' | 'UPGRADE' | 'DOWNGRADE' | 'RENEWAL' | 'REFUND';

export interface SubscriptionFeatures {
  analytics: boolean;
  backups: boolean;
  bulkOperations: boolean;
  apiAccess: boolean;
  prioritySupport: boolean;
  maxCustomers: number;
  maxSuppliers: number;
  maxStorage: number; // in MB
  posMode?: boolean;
  whatsappIntegration?: boolean;
  deliveryTracking?: boolean;
  pdfExport?: boolean;
  multiUser?: boolean;
}

export interface SubscriptionPricing {
  id: string;
  planId: string;
  duration: SubscriptionDuration;
  price: number;
  discount: number;
  isActive: boolean;
}

export interface SubscriptionPlan {
  id: string;
  name: string;
  displayName: string;
  description?: string;
  features: SubscriptionFeatures;
  sortOrder: number;
  isActive: boolean;
  isPopular: boolean;
  pricingOptions: SubscriptionPricing[];
}

export interface UserSubscription {
  id: string;
  userId: string;
  planId: string;
  plan: SubscriptionPlan;
  status: SubscriptionStatus;
  startDate: string;
  endDate: string;
  autoRenew: boolean;
  currentPeriodStart: string;
  currentPeriodEnd: string;
  razorpaySubscriptionId?: string;
  nextBillingAt?: string;
  paymentMethod?: string;
  cancelledAt?: string;
  createdAt: string;
  updatedAt: string;
}

export interface BillingTransaction {
  id: string;
  userId: string;
  planId: string;
  plan?: SubscriptionPlan;
  type: TransactionType;
  amount: number;
  razorpayOrderId: string;
  razorpayPaymentId?: string;
  status: 'pending' | 'completed' | 'failed' | 'refunded';
  paidAt?: string;
  refundedAt?: string;
  createdAt: string;
}

export interface BillingHistory {
  total: number;
  page: number;
  limit: number;
  transactions: BillingTransaction[];
}

export interface UsageStats {
  customers: {
    current: number;
    limit: number;
    percentage: number;
  };
  suppliers: {
    current: number;
    limit: number;
    percentage: number;
  };
  storage: {
    current: number;
    limit: number;
    percentage: number;
  };
}

export interface ProratedCalculation {
  oldPlan: string;
  newPlan: string;
  oldMonthlyPrice: number;
  newMonthlyPrice: number;
  daysRemaining: number;
  totalDays: number;
  proratedAmount: number;
  fullPrice: number;
  discount: number;
}

export interface SubscriptionData {
  tier: SubscriptionTier;
  tierName: string;
  features: SubscriptionFeatures;
  customerLimit: number;
  currentCustomers: number;
  canAddCustomers: boolean;
  supplierLimit: number;
  currentSuppliers: number;
  canAddSuppliers: boolean;
  isTrial: boolean;
  trialUsed: boolean;
  daysRemaining?: number;
  expiresAt?: string;
  isActive: boolean;
  autoRenew?: boolean;
  paymentMethod?: string | null;
  nextBillingAt?: string | null;
  startDate?: string | null;
  endDate?: string | null;
  status?: string;
  price?: number;
}

export interface PricingPlan {
  tier: SubscriptionTier;
  name: string;
  price: string;
  period: string;
  features: string[];
  highlighted?: boolean;
  popular?: boolean;
}

// Multi-Business Types
export interface BusinessSummary {
  id: string;
  name: string;
  type: string;
  joinCode: string;
  sortOrder: number;
  createdAt: string;
  dataUserId: string;
  isActive?: boolean;
}

export interface BusinessJoinRequest {
  id: string;
  businessId: string;
  userId: string;
  status: 'pending' | 'approved' | 'rejected';
  role: string;
  createdAt: string;
}

// Delivery Mode Types
export interface DeliverySessionStop {
  customerId: string;
  customerName: string;
  customerPhone: string;
  customerAddress?: string;
  latitude?: number;
  longitude?: number;
  order: number; // Sequence in optimized route
  status: 'PENDING' | 'IN_PROGRESS' | 'COMPLETED' | 'SKIPPED';
  distanceFromStart: number; // meters
  eta: number; // minutes
  arrivalTime?: string; // ISO timestamp when marked as in-progress
  completionTime?: string; // ISO timestamp when marked as completed
  skipReason?: string;
  deliveryId?: string; // Reference to MilkOutEntry if delivery was recorded
  milkQuantity?: number;
  milkType?: 'COW' | 'BUFFALO';
  milkRevenue?: number;
}

export interface DeliverySession {
  id: string;
  date: string; // YYYY-MM-DD
  startTime: string; // ISO timestamp
  endTime?: string; // ISO timestamp
  status: 'IN_PROGRESS' | 'COMPLETED' | 'CANCELLED';
  shift?: string;
  stops: DeliverySessionStop[];
  stats: {
    totalStops: number;
    completedStops: number;
    skippedStops: number;
    pendingStops: number;
    totalDistance: number; // meters
    totalDuration: number; // minutes
    totalMilkDelivered?: number;
    totalRevenue?: number;
    totalCowMilk?: number;
    totalBuffaloMilk?: number;
    optimizedDistance?: number;
    naiveDistance?: number;
    distanceSaved?: number;
    fuelSaved?: number;
  };
  startLocation: {
    latitude: number;
    longitude: number;
  };
  endLocation?: {
    latitude: number;
    longitude: number;
  };
  createdAt: string;
  updatedAt: string;
}

export interface DeliverySessionCreateInput {
  date: string;
  startTime: string;
  stops: DeliverySessionStop[];
  startLocation: {
    latitude: number;
    longitude: number;
  };
}

export interface SubscriptionAddon {
  id: string;
  name: string;
  displayName: string;
  description?: string;
  price: number;
  features: Record<string, unknown>;
  isActive: boolean;
  sortOrder: number;
  userAddon: { id: string; isActive: boolean; expiresAt?: string } | null;
  alreadyInPlan: boolean;
}

export interface PriceAnnouncement {
  id: string;
  planId: string;
  planName: string;
  currentPrice: number;
  newMonthlyPrice: number;
  effectiveDate: string;
  message?: string;
}

export interface DeliverySessionUpdateInput {
  endTime?: string;
  status?: DeliveryStatus;
  stops?: DeliverySessionStop[];
  endLocation?: {
    latitude: number;
    longitude: number;
  };
  totalMilkDelivered?: number;
  totalRevenue?: number;
  totalCowMilk?: number;
  totalBuffaloMilk?: number;
  totalDistance?: number;
  duration?: number;
  optimizedDistance?: number;
  naiveDistance?: number;
  distanceSaved?: number;
  fuelSaved?: number;
}
